<body>

<div class="crt-overlay"></div>

<div class="screen">
<div id="output">
<p>SYNTEC(TM) PEGASUS OS v2.0.1</p>
<p>COPYRIGHT 1986 SYNTEC LABS</p>
<p>---------------------------</p>
<p>PLEASE LOG IN TO PROCEED...</p>
</div>

<div class="input-area">
<span id="label">LOGIN:&nbsp;</span>
<input type="text" id="command-line" autofocus autocomplete="off">
</div>
</div>

<script>
const input = document.getElementById('command-line');
const output = document.getElementById('output');
const label = document.getElementById('label');

let stage = 0;
let locked = false;

// TYPEWRITER EFFECT
function typeLine(text, speed = 25) {
return new Promise(resolve => {
const p = document.createElement('p');
output.appendChild(p);

let i = 0;
function type() {
if (i < text.length) {
p.textContent += text.charAt(i);
i++;
setTimeout(type, speed);
} else {
output.scrollTop = output.scrollHeight;
resolve();
}
}
type();
});
}

// NORMALIZE INPUT
function normalize(str) {
return str
.toLowerCase()
.replace(/[^\w\s]/g, '')
.trim();
}

// HANDLE INPUT
input.addEventListener('keydown', async function(e) {
if (e.key === 'Enter' && !locked) {
locked = true;

const raw = input.value;
const cmd = raw.trim();
const norm = normalize(raw);

await typeLine("> " + cmd, 15);

input.value = '';

await processInput(cmd, norm);

locked = false;
}
});

async function processInput(cmd, norm) {

switch(stage) {

// LOGIN
case 0:
if (cmd.toUpperCase() === 'W015' || cmd.toUpperCase() === 'J13') {
await typeLine("ACCESS GRANTED...", 30);
await delay(400);
await typeLine("INITIALIZING...", 30);
await delay(500);

stage = 1;
label.textContent = "";
await typeLine("Status report", 30);

} else {
await typeLine("ERROR: INVALID CREDENTIALS", 30);
}
break;

// STATUS REPORT
case 1:
if (norm === "theyre out of cream in the breakroom") {
await delay(300);
await typeLine("Regular or vanilla?", 30);
stage = 2;
} else {
await typeLine("invalid prompt", 30);
}
break;

// FINAL CHOICE
case 2:
const choice = norm;

if (choice === "hazelnut") {
await typeLine("order confirmed", 30);
await delay(700);
window.location.href = "pegasus.html";
}
else if (choice === "peppermint") {
await typeLine("order confirmed", 30);
await delay(700);
window.location.href = "863.html";
}
else if (choice === "vanilla") {
await typeLine("invalid prompt", 30);
}
else {
await typeLine("invalid prompt", 30);
}
break;

}
}

// SIMPLE DELAY
function delay(ms) {
return new Promise(resolve => setTimeout(resolve, ms));
}
</script>

